# Copy to .env and adjust as needed: cp .env.example .env

# Bind address inside the container
HOST=0.0.0.0

# Port the app listens on inside the container
PORT=8000

# Port exposed on the host
HOST_PORT=8000

# Database file path inside the container (lives on the persistent volume)
DATABASE_PATH=/data/database.json

# Mark the session cookie Secure (truthy: 1/true/yes/on). Enable this when the
# app is served over HTTPS — typically behind a TLS-terminating reverse proxy.
# Leave empty or unset for plain-HTTP local development. CLI overrides:
# --https / --no-https.
USE_HTTPS=
